{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "paths": {
      "@/*": ["./src/*"]
    },
    "baseUrl": "."
  },
  "include": [
    "src/cli/**/*.ts",
    "src/lib/**/*.ts",
    "src/parsers/**/*.ts",
    "src/detectors/**/*.ts",
    "src/scoring/**/*.ts",
    "src/llm/**/*.ts"
  ],
  "exclude": [
    "src/app/**",
    "src/components/**",
    "node_modules"
  ]
}
